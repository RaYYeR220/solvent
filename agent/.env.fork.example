# Fork demo env template — Phase 1 swap scenario (USDY vault on a Mantle fork).
#
# Copy to `agent/.env.fork`, paste the VAULT_ADDRESS printed by SetupDemoFork,
# then run the agent once against the fork:
#   cd agent && node --env-file=.env.fork --import tsx src/runtime/main.ts --once
# (or: set -a; source .env.fork; set +a; npx tsx src/runtime/main.ts --once)
#
# Unlike .env.example (live mainnet), this points everything at the local anvil
# fork and at the thin USDY/USDC f100 pool, so a depeg swap is observable.

# --- RPC: local anvil fork ---
MANTLE_RPC_URL=http://localhost:8545

# --- Vault (paste the fork vault from SetupDemoFork output) ---
VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# --- Agent identity ---
# Anvil acct 0 key — on the fork the vault's agent is the real AGENT_EOA, so for
# a live demo set the vault's agent to acct0 OR use the real agent hot key.
AGENT_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
AGENT_ID=106

# --- Assets: USDY (risk, 18dec) -> USDC (safe, 6dec) ---
ASSET_ADDRESS=0x5bE26527e817998A7206475496fDE1E68957c5A6
SAFE_ASSET_ADDRESS=0x09Bc4E0D864854c6aFB6eB9A9cdF58aC190D0dF9
ASSET_DECIMALS=18
SAFE_DECIMALS=6

# --- Agni quoter / fee tier for the USDY/USDC f100 pool (env-overridable) ---
QUOTER_ADDRESS=0xc4aaDc921E1cdb66c5300Bc158a313292923C0cb
FEE_TIER=100

# --- Optional IPFS pinning (empty => base64 data: URI in calldata) ---
PINATA_JWT=

# --- Policy ---
# ALLOWED_ACTIONS must match the vault's on-chain policy.allowedActions:
#   - Phase 1 (swap-only):     2  = (1<<SWAP_TO_SAFE)
#   - Phase 5 (bridge demo):  14  = swap|bridge|unwind
#                                 = (1<<1)|(1<<2)|(1<<3)
# The bridge scenario (SetupDemoFork with bridgeVenue set) needs 14 so the agent
# can BRIDGE_VIA_LENDING on the EARLY depeg and UNWIND_BRIDGE on the re-peg.
ALLOWED_ACTIONS=14
POLL_INTERVAL_MS=6000
WATCH_DIVERGENCE_BPS=20
EARLY_DIVERGENCE_BPS=50
TERMINAL_DIVERGENCE_BPS=500
# USDY NAV (Ondo) vs Agni market can legitimately diverge a lot once the pool is
# crashed; keep the oracle-untrusted ceiling high so a real depeg still escalates
# past WATCH. (No cross-check price source is wired here, so this stays 0 anyway.)
MAX_ORACLE_DIVERGENCE_BPS=10000
LIQUIDITY_FLOOR=0
MAX_SLIPPAGE_BPS=300
MAX_BRIDGE_LTV_BPS=5000
# Liquidity probe sizes in USDY 18-dec units (10, 100, 1000 USDY).
LIQUIDITY_PROBE_SIZES=10000000000000000000,100000000000000000000,1000000000000000000000
