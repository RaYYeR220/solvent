# Copy to `agent/.env` and fill in the secret AGENT_PRIVATE_KEY.
# The other values are deployment constants; safe to keep as-is unless
# Ondo allowlist arrives and we redeploy with USDY.
#
# This file is consumed by `import "dotenv/config"` at the top of
# src/runtime/main.ts when you run `npm run tick` locally. CI doesn't
# read it — the GitHub Actions workflow injects env vars directly.

# --- Secret (NEVER commit) ---
# Hot key for agent EOA 0x8D8BB77189a95eFF0D45EB08A75e35DcA8a1432c.
# Copy from contracts/.env (the AGENT_PRIVATE_KEY entry from Plan 6 Task 1.7).
AGENT_PRIVATE_KEY=0x...

# --- RPC ---
MANTLE_RPC_URL=https://rpc.mantle.xyz

# --- Optional: Pinata for IPFS pinning ---
# Get a JWT at https://app.pinata.cloud/developers/api-keys (free tier).
# If empty, the agent falls back to base64 data: URIs in calldata.
PINATA_JWT=

# --- Deployment constants ---
# Solvent vault address (Mantle mainnet).
# As of 2026-05-30 this is the V2 ERC-4626 vault.
# V1 kept as deprecated reference at 0x06513470e16a7d6071A12708c38a6fa0ED66469c (kill-switched on-chain).
VAULT_ADDRESS=0xDDEd84Ef1ceA80af70b23B599cC9672a15c57c9f
AGENT_ID=106
ASSET_ADDRESS=0x779Ded0c9e1022225f8E0630b35a9b54bE713736
SAFE_ASSET_ADDRESS=0x09Bc4E0D864854c6aFB6eB9A9cdF58aC190D0dF9
ASSET_DECIMALS=6
SAFE_DECIMALS=6

# --- Policy (mirrors on-chain SolventVaultV2.policy) ---
POLL_INTERVAL_MS=300000
WATCH_DIVERGENCE_BPS=20
EARLY_DIVERGENCE_BPS=50
TERMINAL_DIVERGENCE_BPS=500
MAX_ORACLE_DIVERGENCE_BPS=100
LIQUIDITY_FLOOR=0
MAX_SLIPPAGE_BPS=300
MAX_BRIDGE_LTV_BPS=5000
# Bitmap: PARK_YIELD (16) | UNWIND_BRIDGE (8) | BRIDGE_VIA_LENDING (4) | SWAP_TO_SAFE (2) = 30
ALLOWED_ACTIONS=30
